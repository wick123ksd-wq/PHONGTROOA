@model IEnumerable<PHONGTROOA.Models.Booking>
<div class="container mt-4 py-5">
    <h2>📋 Admin - Quản lý đặt phòng</h2>

    <table class="table table-bordered text-center align-middle">

        <thead class="table-dark">
            <tr>
                <th>Room</th>
                <th>Time</th>
                <th>Tenant</th>
                <th>People</th>
                <th>Note</th>
                <th>Payment</th>
                <th>Slip</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <!-- 🏠 Room -->
                    <td>@item.Phong?.TenPhong</td>

                    <!-- 📅 Time -->
                    <td>
                        @item.StartDate?.ToString("dd/MM/yyyy")
                        <br /> →
                        <br />
                        @item.EndDate?.ToString("dd/MM/yyyy")
                    </td>

                    <!-- 👤 Tenant -->
                    <td>
                        <b>@item.FullName</b><br />
                        📞 @item.Phone
                    </td>

                    <!-- 👥 People -->
                    <td>@item.People</td>

                    <!-- 📝 Note -->
                    <td>@item.Note</td>

                    <!-- 💳 Payment -->
                    <td>@item.PaymentMethod</td>

                    <!-- 🖼️ Slip -->
                    <td>
                        @if (!string.IsNullOrEmpty(item.Payment?.SlipImage))
                        {
                            <img src="@item.Payment.SlipImage"
                                 width="80"
                                 style="cursor:pointer"
                                 onclick="showImage('@item.Payment.SlipImage')" />
                        }
                        else
                        {
                            <span class="text-muted">No slip</span>
                        }
                    </td>

                    <!-- 🎨 Status -->
                    <td>
                        @if (item.Payment?.Status == "Approved")
                        {
                            <span class="badge bg-success">Approved</span>
                        }
                        else if (item.Payment?.Status == "Rejected")
                        {
                            <span class="badge bg-danger">Rejected</span>
                        }
                        else if (item.Payment?.Status == "Uploaded")
                        {
                            <span class="badge bg-info">Uploaded</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Pending</span>
                        }
                    </td>

                    <!-- ⚙️ Action -->
                    <td>
                        @if (item.Payment?.Status == "Uploaded")
                        {
                            <a href="/Admin/Approve?id=@item.Id"
                               class="btn btn-success btn-sm">Approve</a>

                            <a href="/Admin/Reject?id=@item.Id"
                               class="btn btn-danger btn-sm">Reject</a>
                        }
                        else
                        {
                            <span class="text-muted">---</span>
                        }
                    </td>
                </tr>
            }
        </tbody>

    </table>

</div>

<!-- 🔍 Modal xem ảnh -->
<div id="imageModal"
     style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:black; z-index:9999; text-align:center;">

    <span onclick="closeImage()"
          style="color:white; font-size:30px; position:absolute; top:20px; right:40px; cursor:pointer;">
        &times;
    </span>

    <img id="modalImg"
         style="max-width:90%; max-height:90%; margin-top:5%;" />
</div>

<script>
    function showImage(src) {
        document.getElementById("imageModal").style.display = "block";
        document.getElementById("modalImg").src = src;
    }

    function closeImage() {
        document.getElementById("imageModal").style.display = "none";
    }
</script>