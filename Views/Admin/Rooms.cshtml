@{
}
@model IEnumerable<PHONGTROOA.Models.Phong>
<div class="container mt-4 py-5">

<h2>Quản lý phòng</h2>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>ID</th>
            <th>Tên phòng</th>
            <th>Giá thuê</th>
            <th>Địa chỉ</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var room in Model)
        {
            <tr>
                <td>@room.MaPhong</td>
                <td>@room.TenPhong</td>
                <td>@room.GiaThue</td>
                <td>@room.DiaChi</td>

                <td>

                    <a asp-controller="Room"
                           asp-action="Edit"
                           asp-route-id="@room.MaPhong"
                           class="btn btn-warning">
                        Sửa
                    </a>

                    <a asp-controller="Room"
                           asp-action="Delete"
                           asp-route-id="@room.MaPhong"
                           class="btn btn-danger">
                        Xóa
                    </a>

                </td>
            </tr>
        }
            <a asp-controller="Room" asp-action="Create"
                   class="btn btn-success mb-3">
                + Thêm phòng mới
            </a>

    </tbody>

</table>
</div>