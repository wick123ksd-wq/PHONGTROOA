@model PHONGTROOA.Models.Booking

<div class="container py-5">

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <!-- ROOM IMAGE -->

        <img src="@Model.Phong.HinhAnh"
             class="img-fluid"
             style="height:350px; object-fit:cover;" />

        <!-- BODY -->

        <div class="card-body p-5">

            <div class="d-flex justify-content-between align-items-start mb-4">

                <div>

                    <h2 class="fw-bold mb-2">
                        @Model.Phong.TenPhong
                    </h2>

                    <p class="text-muted mb-0">
                        <i class="bi bi-geo-alt"></i>
                        @Model.Phong.DiaChi
                    </p>

                </div>

                <!-- STATUS -->

                <div>

                    @if (Model.Status == "Pending")
                    {
                        <span class="badge bg-warning text-dark p-2 px-3">
                            Pending
                        </span>
                    }
                    else if (Model.Status == "Confirmed")
                    {
                        <span class="badge bg-success p-2 px-3">
                            Confirmed
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger p-2 px-3">
                            Rejected
                        </span>
                    }

                </div>

            </div>

            <hr />

            <!-- INFO -->

            <div class="row mt-4">

                <div class="col-md-6">

                    <div class="mb-4">

                        <h5 class="fw-bold">
                            📅 Thông tin thuê
                        </h5>

                        <p class="mb-2">
                            <strong>Ngày thuê:</strong>
                            @Model.StartDate?.ToString("dd/MM/yyyy")
                        </p>

                        <p class="mb-2">
                            <strong>Ngày hết hạn:</strong>
                            @Model.EndDate?.ToString("dd/MM/yyyy")
                        </p>

                        <p class="mb-2">
                            <strong>Số tháng:</strong>
                            @Model.Months
                        </p>

                    </div>

                </div>

                <div class="col-md-6">

                    <div class="mb-4">

                        <h5 class="fw-bold">
                            💳 Thanh toán
                        </h5>

                        <p class="mb-2">
                            <strong>Tổng tiền:</strong>
                            <span class="text-primary fw-bold">
                                @((Model.Phong.GiaThue * Model.Months).ToString("N0")) đ
                            </span>
                        </p>

                        <p class="mb-2">
                            <strong>Phương thức:</strong>
                            @Model.PaymentMethod
                        </p>

                    </div>

                </div>

            </div>

            <!-- USER INFO -->

            <div class="mt-4">

                <h5 class="fw-bold mb-3">
                    👤 Thông tin người thuê
                </h5>

                <div class="row">

                    <div class="col-md-6">

                        <p>
                            <strong>Họ tên:</strong>
                            @Model.FullName
                        </p>

                    </div>

                    <div class="col-md-6">

                        <p>
                            <strong>Số điện thoại:</strong>
                            @Model.Phone
                        </p>

                    </div>

                </div>

                <p>
                    <strong>Số người:</strong>
                    @Model.People
                </p>

                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <p>
                        <strong>Ghi chú:</strong>
                        @Model.Note
                    </p>
                }

            </div>

            <!-- BUTTON -->

            <div class="mt-5">

                <a asp-action="MyBookings"
                   class="btn btn-primary px-4 rounded-3">

                    <i class="bi bi-arrow-left"></i>
                    Quay lại
                </a>

            </div>

        </div>

    </div>

</div>