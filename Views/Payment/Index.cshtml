@model IEnumerable<PHONGTROOA.Models.Payment>

<h2>Payment Management</h2>

<table class="table">
    <thead>
        <tr>
            <th>Room</th>
            <th>Price</th>
            <th>Status</th>
            <th>Slip</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Booking?.Phong?.TenPhong</td>

                <td>@item.Booking?.TotalPrice.ToString("N0") đ</td>

                <td>
                    @if (item.Status == "Pending")
                    {
                        <span class="badge bg-warning">Pending</span>
                    }
                    else if (item.Status == "Approved")
                    {
                        <span class="badge bg-success">Paid</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Rejected</span>
                    }
                </td>

                <td>
                    <a href="/Payment/View/@item.BookingId">View</a>
                </td>

                <td>
                    <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-success">✔</a>
                    <a asp-action="Reject" asp-route-id="@item.Id" class="btn btn-danger">✖</a>
                </td>
            </tr>
        }
    </tbody>
</table>