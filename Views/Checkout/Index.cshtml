@model PHONGTROOA.Models.Cart

<div class="container mt-4 py-5">

    <h2>💳 Thanh toán</h2>

    @if (Model == null || Model.Items.Count == 0)
    {
        <p>Không có gì để thanh toán</p>
    }
    else
    {
        decimal total = 0;

        <table class="table">
            <tr>
                <th>Phòng</th>
                <th>Tháng</th>
                <th>Tổng</th>
            </tr>

            @foreach (var item in Model.Items)
            {
                var price = item.Phong?.GiaThue ?? 0;
                var money = price * item.Quantity;

                total += money;

                <tr>
                    <td>@item.Phong?.TenPhong</td>
                    <td>@item.Quantity</td>
                    <td>@money.ToString("N0") đ</td>
                </tr>
            }
        </table>

        <h4 class="text-danger">Tổng tiền: @total.ToString("N0") đ</h4>

        <hr />

        <!-- 🔥 ฟอร์มโปร -->
        <form asp-action="Confirm" method="post">

            <h5>📋 Thông tin người thuê</h5>

            <input name="FullName" class="form-control mb-2" placeholder="Họ tên" required />
            <input name="Phone" class="form-control mb-2" placeholder="Số điện thoại" required />

            <input type="number" name="People" class="form-control mb-2" min="1" value="1" />

            <textarea name="Note" class="form-control mb-2" placeholder="Ghi chú thêm..."></textarea>

            <select name="PaymentMethod" class="form-control mb-3">
                <option value="QR">Chuyển khoản</option>
                <option value="Cash">Tiền mặt</option>
            </select>

            <button class="btn btn-success w-100">
                ✔ Xác nhận thanh toán
            </button>

        </form>
    }
</div>