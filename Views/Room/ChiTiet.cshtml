@{
}
@model PHONGTROOA.Models.Phong
<br />
<br />
<div class="container mt-4 py-5">
<h2>@Model.TenPhong</h2>

<div class="card shadow p-3">

    @if (!string.IsNullOrEmpty(Model.HinhAnh))
    {
            <img src="@Url.Content(Model.HinhAnh)"
                 class="img-fluid rounded"
                 style="width:100%; height:400px; object-fit:cover;">
    }
    <br />
    <h4 class="text-danger">
        @Model.GiaThue.ToString("N0") đ / tháng
    </h4>

        <p class="fs-5"><strong>Diện tích:</strong> @Model.DienTich m²</p>
        <p class="fs-5"><strong>Địa chỉ:</strong> @Model.DiaChi</p>
        <p class="fs-5"><strong>Ngày đăng:</strong> @Model.NgayDang.ToString("dd/MM/yyyy")</p>

    <br />
        <div class="d-flex gap-2 mt-3">

            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit"
                       asp-route-id="@Model.MaPhong"
                       class="btn btn-primary btn-lg">
                    Sửa
                </a>

                <a asp-action="Delete"
                       asp-route-id="@Model.MaPhong"
                       class="btn btn-danger btn-lg">
                    Xóa
                </a>
            } 
            @if (User?.Identity?.IsAuthenticated==true)
            {
                <a asp-controller="Booking"
                       asp-action="Create"
                       asp-route-roomId="@Model.MaPhong"
                       class="btn btn-success">
                    Đặt phòng
                </a>
                <a asp-controller="Cart"
                       asp-action="AddToCart"
                       asp-route-id="@Model.MaPhong"
                       class="btn btn-success">
                    Thêm vào giỏ
                </a>
             }
            <form asp-controller="Cart" asp-action="AddToCart" method="get">

                <!-- 🔥 สำคัญมาก -->
                <input type="hidden" name="id" value="@Model.MaPhong" />

                <label>Chọn ngày bắt đầu:</label>
                <input type="date" name="startDate" class="form-control" required />

                <label>Số tháng:</label>
                <input type="number" name="months" value="1" min="1" class="form-control" required />

                <br />

                <button type="submit" class="btn btn-warning">
                    Thêm vào giỏ
                </button>

            </form>
            <a asp-action="Index"
                   class="btn btn-secondary btn-lg">
                Quay lại
            </a>

        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["Error"] != null)
{
    <script>
        Swal.fire({
        icon: 'error',
        title: 'Error',
        text: '@Html.Raw(TempData["Error"])'
        });
    </script>
}